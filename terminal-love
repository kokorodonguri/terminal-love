#!/usr/bin/env python3
import sys
import shutil
import time
import math
import select
import termios
import tty
import re
import os

def get_cpu_temp():
    """CPU温度を取得（摂氏）"""
    try:
        with open("/sys/class/thermal/thermal_zone0/temp", "r") as f:
            return int(f.read()) / 1000.0
    except Exception:
        return 50.0

def get_mem_usage():
    """メモリ使用率（0.0 〜 1.0）を取得"""
    try:
        with open("/proc/meminfo", "r") as f:
            meminfo = f.read()
        total_match = re.search(r"^MemTotal:\s+(\d+)", meminfo, re.MULTILINE)
        avail_match = re.search(r"^MemAvailable:\s+(\d+)", meminfo, re.MULTILINE)
        if total_match and avail_match:
            total = int(total_match.group(1))
            avail = int(avail_match.group(1))
            return (total - avail) / total
    except Exception:
        pass
    return 0.5

def draw_ultimate_heart():
    # カーソルを隠し、マウストラッキングを有効化
    sys.stdout.write("\033[?25l\033[?1003h\033[?1015h\033[?1006h")
    sys.stdout.flush()

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    tty.setcbreak(fd)

    try:
        cols, rows = shutil.get_terminal_size()
        target_x = cols / 2
        target_y = rows / 2

        last_check = 0
        mem_ratio = 0.0
        cpu_temp = 50.0

        while True:
            current_time = time.time()
            cols, rows = shutil.get_terminal_size()
            
            # システム情報は1秒に1回更新
            if current_time - last_check > 1.0:
                mem_ratio = get_mem_usage()
                cpu_temp = get_cpu_temp()
                last_check = current_time

            temp_ratio = max(0.0, min(1.0, (cpu_temp - 35.0) / 50.0))
            
            # 現在のCPU温度に応じたアクティブカラー
            current_r = int(max(0, min(255, 2 * temp_ratio * 255)))
            current_g = int(max(0, min(255, 2 * (1.0 - temp_ratio) * 255)))
            current_b = 30
            active_color = f"\033[38;2;{current_r};{current_g};{current_b}m"

            # マウス座標の取得
            if select.select([sys.stdin], [], [], 0)[0]:
                try:
                    data = os.read(fd, 1024).decode('utf-8')
                    matches = re.findall(r'\033\[<(\d+);(\d+);(\d+)([mM])', data)
                    if matches:
                        target_x = int(matches[-1][1])
                        target_y = rows - int(matches[-1][2])
                except Exception:
                    pass

            frame = "\033[H" 

            mouse_nx = (target_x / cols - 0.5) * 3.0 * (cols / rows) * 0.45
            mouse_ny = (target_y / rows - 0.4) * 2.5

            # ハート本体の描画ループ
            for y in range(rows - 2, -1, -1):
                line = ""
                height_ratio = min(1.0, y / (rows * 0.85))

                for x in range(cols):
                    base_nx = (x / cols - 0.5) * 3.0 * (cols / rows) * 0.45
                    base_ny = (y / rows - 0.4) * 2.5
                    
                    dx = base_nx - mouse_nx
                    dy = base_ny - mouse_ny
                    dist = math.hypot(dx, dy)
                    
                    wave = math.sin(dist * 15.0 - current_time * 15.0)
                    amplitude = 0.15 * math.exp(-dist * 2.5)
                    offset = wave * amplitude
                    
                    if dist > 0.001:
                        nx = base_nx + (dx / dist) * offset
                        ny = base_ny + (dy / dist) * offset
                    else:
                        nx = base_nx
                        ny = base_ny
                    
                    if (nx**2 + ny**2 - 1)**3 - (nx**2) * (ny**3) <= 0:
                        if height_ratio <= mem_ratio:
                            line += f"{active_color}♥\033[0m"
                        else:
                            line += "\033[38;2;60;60;60m♥\033[0m"
                    else:
                        line += " "
                frame += line + "\n"
            
            # --- ここからステータスとカラーバーの描画 ---
            
            # 1行目: 数値ステータス
            status_text = f"\033[H\033[37m Mem: {mem_ratio * 100:.1f}% | CPU: {cpu_temp:.1f}°C \033[0m"
            
            # 2行目: 温度カラーのグラデーションサンプル（25段階のブロック）
            bar_text = "\033[2;1H\033[37m  35C \033[0m"
            for i in range(25):
                ratio = i / 24.0
                bar_r = int(max(0, min(255, 2 * ratio * 255)))
                bar_g = int(max(0, min(255, 2 * (1.0 - ratio) * 255)))
                bar_text += f"\033[38;2;{bar_r};{bar_g};30m█"
            bar_text += "\033[0m\033[37m 85C\033[0m"
            
            # 3行目: 現在の温度を示すインジケーター（▲）
            # 25ブロックの中で現在の比率がどこに該当するか計算
            pos = int(temp_ratio * 24)
            # "  35C " の6文字分のスペースを空けて位置を合わせる
            indicator = "\033[3;1H" + " " * (6 + pos) + "\033[37m▲\033[0m"

            # フレームの最後に結合
            frame += status_text + bar_text + indicator

            sys.stdout.write(frame)
            sys.stdout.flush()
            time.sleep(0.04)

    except KeyboardInterrupt:
        pass
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
        sys.stdout.write("\033[?1006l\033[?1015l\033[?1003l\033[?25h\033[2J\033[H")
        sys.stdout.flush()

if __name__ == "__main__":
    draw_ultimate_heart()
